# syntax=docker/dockerfile:1
# =============================================================================
# AGENTBOX MANAGED -- DO NOT EDIT THIS STAGE
# This stage is regenerated by `agentbox update`. Any manual changes will be
# overwritten. Add your customizations to the "custom" stage at the bottom.
# =============================================================================
FROM debian:bookworm-slim AS agentbox

# --- Locale ---
ENV LANG=en_US.UTF-8
RUN apt-get update && apt-get install -y locales \
    && sed -i '/en_US.UTF-8/s/^# //' /etc/locale.gen \
    && locale-gen

# --- System packages ---
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git sudo zsh ca-certificates gnupg \
    iptables ipset iproute2 dnsutils dnsmasq \
    build-essential jq fzf \
    && rm -rf /var/lib/apt/lists/*

# --- GitHub CLI (gh) ---
RUN (curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg) \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# --- Create non-root user ---
RUN groupadd --gid 1000 node \
    && useradd --uid 1000 --gid node --shell /bin/zsh --create-home node \
    && echo 'node ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers.d/node

# --- Mise (runtime manager) ---
# NOTE: curl|sh trusts mise.jdx.dev; consider pinning to a release with
# checksum verification for hardened environments.
RUN curl https://mise.jdx.dev/install.sh | sh \
    && cp /root/.local/bin/mise /usr/local/bin/mise

# --- Runtime configuration ---
# Managed by mise; edit .devcontainer/config.toml to change versions.
COPY config.toml /home/node/.config/mise/config.toml

# --- Install runtimes via mise (as node user so $HOME matches config path) ---
RUN chown -R node:node /home/node/.config
USER node
ENV PATH="/home/node/.local/share/mise/shims:/home/node/.local/bin:${PATH}"
RUN mise install

# --- LSP servers ---
RUN go install golang.org/x/tools/gopls@latest

# --- Dev tools ---
RUN go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@latest

# --- Claude Code ---
RUN npm install -g @anthropic-ai/claude-code

USER root

# --- QoL: git-delta ---
RUN ARCH=$(dpkg --print-architecture) \
    && curl -fsSL -o /tmp/delta.deb \
       https://github.com/dandavison/delta/releases/download/0.18.2/git-delta_0.18.2_${ARCH}.deb \
    && dpkg -i /tmp/delta.deb \
    && rm /tmp/delta.deb

# --- Firewall scripts ---
# Note: dynamic-domains.conf is a reference file, not a dnsmasq config.
# The init-firewall.sh script writes the actual dnsmasq configuration
# (upstream DNS forwarding + ipset directives) to /etc/dnsmasq.d/agentbox.conf
# at container start.
COPY init-firewall.sh /usr/local/bin/init-firewall.sh
COPY warmup-dns.sh /usr/local/bin/warmup-dns.sh
RUN chmod +x /usr/local/bin/init-firewall.sh /usr/local/bin/warmup-dns.sh

USER node

# --- QoL: zsh-in-docker (must run as node so config goes to /home/node) ---
RUN sh -c "$(curl -fsSL https://github.com/deluan/zsh-in-docker/releases/download/v1.2.1/zsh-in-docker.sh)" -- \
    -t robbyrussell

WORKDIR /workspace

FROM agentbox AS custom

# =============================================================================
# USER CUSTOMIZATIONS
# =============================================================================
# Add your project-specific tools and configuration below.
# This stage is preserved when running `agentbox update`.
#
# Examples:
#   RUN go install github.com/user/tool@latest
#   RUN npm install -g some-cli
#   RUN pip install my-tool
#   COPY my-config.toml /home/node/.config/my-tool/config.toml
#
# The agentbox stage above provides: mise runtimes, LSP servers, Claude Code,
# firewall scripts, and all system dependencies. Your customizations layer
# on top via Docker's multi-stage build caching.
# =============================================================================

# --- Project tools ---
RUN go install github.com/hmans/beans@latest

# Disable adaptive thinking for now
ENV CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1